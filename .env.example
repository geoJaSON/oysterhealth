# --- Database ---
POSTGRES_DB=oyster_health
POSTGRES_USER=oyster_user
POSTGRES_PASSWORD=change_me_locally
# Host:port used by scripts running on the Windows host. The container always
# listens on 5432 internally; only the host port mapping changes.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# Backend connection (asyncpg). NOTE: any special chars in the password must
# be URL-encoded here (e.g., % → %25, & → %26, @ → %40, # → %23).
DATABASE_URL=postgresql+asyncpg://oyster_user:change_me_locally@db:5432/oyster_health
# Scripts/Celery connection (psycopg / sync)
DATABASE_URL_SYNC=postgresql://oyster_user:change_me_locally@db:5432/oyster_health

# --- Redis ---
# Host-run dev: the compose redis container publishes 6379 on localhost.
# The docker `full` profile overrides this to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0

# --- Copernicus Marine (register at marine.copernicus.eu) ---
CMEMS_USERNAME=
CMEMS_PASSWORD=

# --- Supabase (inactive at launch) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Toggle auth enforcement on protected routes
AUTH_REQUIRED=false

# --- App ---
APP_ENV=development
API_BASE_URL=http://localhost:8000/api
# Comma-separated origins for the FastAPI CORS middleware. Frontend runs on
# 5273 (not Vite's default 5173, which collides with other local projects).
CORS_ORIGINS=http://localhost:5273,http://127.0.0.1:5273

# --- Frontend (Vite reads VITE_*) ---
VITE_API_BASE_URL=http://localhost:8000/api
