# Production .env template — copy to `.env` on the VPS and fill in.
# Unlike .env.example (host dev), these use CONTAINER networking: the backend,
# workers, and beat all talk to the `db` and `redis` services by name.

# --- Database ---
POSTGRES_DB=oyster_health
POSTGRES_USER=oyster_user
# Use a long random secret (e.g. `openssl rand -base64 32`). If it contains URL
# meta-chars they're handled — settings builds the DSN from these components.
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_SECRET
# CONTAINER values (NOT localhost/5433). The backend reaches Postgres at db:5432.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (container service name) ---
REDIS_URL=redis://redis:6379/0

# --- Web / TLS ---
# Your domain → Caddy issues Let's Encrypt TLS automatically. Use ":80" only for
# pre-DNS testing (plain HTTP, no cert).
SITE_ADDRESS=oysterhealth.example.com
# FastAPI CORS. The SPA calls /api same-origin via Caddy, so this is the public
# origin(s). Include www if you serve it.
CORS_ORIGINS=https://oysterhealth.example.com

# --- App ---
APP_ENV=production

# --- Copernicus Marine (modeled salinity; leave blank to skip CMEMS fetches) ---
CMEMS_USERNAME=
CMEMS_PASSWORD=

# --- Supabase (inactive at launch) ---
AUTH_REQUIRED=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
